                              "content": "// @MX:ANCHOR auth_token_rotation",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "NvrxG",
                              "fill": "$fg-primary",
                              "content": "pub async fn rotate_token(",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "gecAb",
                              "fill": "$fg-secondary",
                              "content": "    session: &Session,",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "QREek",
                              "fill": "$fg-secondary",
                              "content": "    store: Arc<dyn TokenStore>,",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "2FUAF",
                              "fill": "$fg-primary",
                              "content": ") -> Result<Token, AuthError> {",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "qRDXZ",
                              "fill": "$status-warning",
                              "content": "    // @MX:WARN legacy_session_store",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "9jprB",
                              "fill": "$fg-secondary",
                              "content": "    let prev = store.get(&session.id).await?;",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "9tjgD",
                              "fill": "$fg-secondary",
                              "content": "    let new_token = Token::generate(Algo::Ed25519);",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "8vsYE",
                              "fill": "$fg-muted",
                              "content": "    // @MX:TODO emit audit log",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "rquok",
                              "fill": "$fg-secondary",
                              "content": "    store.replace(&session.id, &new_token).await?;",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "c3XlD",
                              "fill": "$fg-primary",
                              "content": "    Ok(new_token)",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "YFwpw",
                              "fill": "$fg-primary",
                              "content": "}",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
