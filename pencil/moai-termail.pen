                      "id": "L91M2",
                      "fill": "$accent-cyan",
                      "content": "$ moai-terminal install-hooks --sink http://localhost:4273",
                      "fontFamily": "Geist Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            },
