                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "ijqce",
                              "fill": "$fg-secondary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "    private var panes: [PaneID: Pane] = [:]",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "r43VB",
                              "fill": "$fg-secondary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "    private let bus: EventBus",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "8M4Ji",
                              "fill": "$fg-secondary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "HhClG",
                              "fill": "$fg-primary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "    public func broadcast(_ event: PaneEvent) async throws {",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "B8u9F",
                              "fill": "$status-error",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "        try await bus.publish(event)  // TODO: retry policy",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "oJLEY",
                              "fill": "$fg-secondary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "        for pane in panes.values where pane.subscribes(to: event.topic) {",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "u342B",
                              "fill": "$fg-secondary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "            await pane.apply(event)",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "jTU2C",
                              "fill": "$fg-secondary",
