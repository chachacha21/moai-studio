                          "children": [
                            {
                              "type": "text",
                              "id": "iHkWk",
                              "fill": "$accent-moai",
                              "content": "// @MX:ANCHOR auth_token_rotation",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "pffK2",
                              "fill": "#18181B",
                              "content": "pub async fn rotate_token(",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "oTN64",
                              "fill": "#71717A",
                              "content": "    session: &Session,",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "mX6nt",
                              "fill": "#71717A",
                              "content": "    store: Arc<dyn TokenStore>,",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "lCNrA",
                              "fill": "#18181B",
                              "content": ") -> Result<Token, AuthError> {",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "8YtHm",
                              "fill": "$status-warning",
                              "content": "    // @MX:WARN legacy_session_store",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "XZDfJ",
                              "fill": "#71717A",
                              "content": "    let prev = store.get(&session.id).await?;",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "4dKUZ",
                              "fill": "#71717A",
                              "content": "    let new_token = Token::generate(Algo::Ed25519);",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "SOtA1",
                              "fill": "#A1A1AA",
                              "content": "    // @MX:TODO emit audit log",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "f8Umn",
                              "fill": "#71717A",
                              "content": "    store.replace(&session.id, &new_token).await?;",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "x9CgM",
                              "fill": "#18181B",
                              "content": "    Ok(new_token)",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "scyK7",
                              "fill": "#18181B",
                              "content": "}",
                              "fontFamily": "Geist Mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    }
