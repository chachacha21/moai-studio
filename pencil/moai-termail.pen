                  "fontFamily": "Geist Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "rJiTp",
                  "fill": "#71717A",
                  "content": "    let new_token = Token::new(Algo::Hs256);",
                  "fontFamily": "Geist Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "uv5M8",
                  "fill": "#71717A",
                  "content": "    store.set(&session.id, &new_token).await?;",
                  "fontFamily": "Geist Mono",
